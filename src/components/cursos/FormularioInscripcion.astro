---
interface Props {
    curso: string;
}

const { curso } = Astro.props;
---

<div class="p-8 md:p-12 backdrop-blur-sm flex flex-col items-center bg-sky-600 rounded-lg">
    <div class="text-center mb-6 text-2xl/6 font-bold text-white">
        Si estás listo o lista para ser un profesional del masaje, este
        es tu momento.
    </div>
    <div class="bg-white rounded-2xl p-6 md:p-8 text-gray-800 shadow-2xl w-full">
        <h4 class="text-center font-black text-xl md:text-2xl mb-6 text-azul leading-tight">
        INÍCIATE EN LA MASOTERAPIA
        </h4>
        <form class="space-y-4" id="form-inscripcion">
        <div>
            <label class="block text-xs font-bold text-gray-500 mb-1 uppercase tracking-wider">Nombre
            Completo</label>
            <input type="text" name="nombre"
            class="w-full bg-gray-50 border border-gray-200 rounded-xl px-4 py-4 focus:outline-none focus:border-azul transition-colors text-base"
            placeholder="Ej: John Doe" required id="nombre" />
        </div>
        <div>
            <label class="block text-xs font-bold text-gray-500 mb-1 uppercase tracking-wider">Correo
            Electrónico</label>
            <input type="email" name="email"
            class="w-full bg-gray-50 border border-gray-200 rounded-xl px-4 py-4 focus:outline-none focus:border-azul transition-colors text-base"
            placeholder="tucorreo@ejemplo.com" required id="email" />
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
            <label class="block text-xs font-bold text-gray-500 mb-1 uppercase tracking-wider">WhatsApp</label>
            <input type="tel" name="telefono"
                class="w-full bg-gray-50 border border-gray-200 rounded-xl px-4 py-4 focus:outline-none focus:border-azul transition-colors text-base"
                placeholder="+56 9..." required id="telefono" />
            </div>
            <div>
            <label class="block text-xs font-bold text-gray-500 mb-1 uppercase tracking-wider">Ciudad</label>
            <input type="text" name="ciudad"
                class="w-full bg-gray-50 border border-gray-200 rounded-xl px-4 py-4 focus:outline-none focus:border-azul transition-colors text-base"
                placeholder="Viña del Mar" required id="ciudad" />
            </div>
            <input type="hidden" name="curso" id="curso" value={curso} />
        </div>
        <button type="submit"
            class="w-full bg-sky-600 text-white font-black py-5 rounded-xl shadow-lg hover:shadow-azul/30 transform hover:-translate-y-1 transition-all uppercase tracking-widest mt-4 text-sm">
            QUIERO MÁS DETALLES
        </button>
        </form>

        <!-- Success Message (Initially Hidden) -->
        <div id="mensaje-exito" class="hidden text-center py-8">
        <div class="mb-4 text-green-500">
            <i class="fas fa-check-circle text-6xl"></i>
        </div>
        <h4 class="text-2xl font-bold text-azul mb-2">
            ¡Solicitud Enviada!
        </h4>
        <p class="text-gray-600">
            Gracias por tu interés. Un asesor se pondrá en contacto
            contigo muy pronto vía WhatsApp o correo electrónico.
        </p>
        </div>
        </div>
    </div>

<script>
    const form = document.getElementById('form-inscripcion') as HTMLFormElement;
    const successMessage = document.getElementById('mensaje-exito');

    if (form && successMessage) {
        form.addEventListener('submit', async (e) => {
            e.preventDefault();

            // Deshabilitar botón durante el envío
            const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
            const originalBtnText = submitBtn.innerText;
            submitBtn.disabled = true;
            submitBtn.innerText = 'ENVIANDO...';

            const formData = new FormData(form);

            try {
                const response = await fetch('https://cenakin.cl/otec/correo4.php', {
                    method: 'POST',
                    body: formData,
                });

                if (response.ok) {
                    form.classList.add('hidden');
                    successMessage.classList.remove('hidden');
                    // Scroll suave hacia el mensaje
                    successMessage.scrollIntoView({ behavior: 'smooth' });
                } else {
                    throw new Error('Error en el servidor');
                }
            } catch (error) {
                console.error('Error:', error);
                alert('No se pudo enviar el formulario. Por favor, inténtalo de nuevo o contáctanos directamente.');
            } finally {
                submitBtn.disabled = false;
                submitBtn.innerText = originalBtnText;
            }
        });
    }
</script>